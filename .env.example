# Copy this file to .env and fill in your values (see SHEETS_SETUP.md)

# The long ID from the sheet URL: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=

# Path to the service account key file you downloaded from Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=service_account.json

# Tab name inside the spreadsheet (bottom-left of the sheet UI)
SHEET_NAME=Sheet1
